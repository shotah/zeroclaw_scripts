{
  "editor.formatOnSave": true,
  "editor.trimAutoWhitespace": true,
  "editor.rulers": [80, 120],
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.eol": "\n",
  "files.associations": {
    ".env": "dotenv",
    ".env.*": "dotenv",
    "Dockerfile*": "dockerfile",
    "docker-compose*.yml": "dockercompose",
    "Makefile": "makefile",
    "*.toml": "toml"
  },
  "files.watcherExclude": {
    "**/data/**": true,
    "**/.git/objects/**": true
  },
  "search.exclude": {
    "**/data/**": true,
    ".env": true
  },
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.formatOnSave": false
  },
  "[yaml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[makefile]": {
    "editor.insertSpaces": false,
    "editor.detectIndentation": false,
    "editor.tabSize": 4
  },
  "yaml.schemas": {
    "https://raw.githubusercontent.com/compose-spec/compose-go/master/schema/compose-spec.json": [
      "docker-compose*.yml",
      "docker-compose*.yaml"
    ]
  },
  "cSpell.enabled": true,
  "cSpell.language": "en",
  "cSpell.ignorePaths": [".git", "data/**", "LICENSE"],
  "cSpell.words": [
    "agentic",
    "alexballas",
    "allowlist",
    "arketa",
    "authuser",
    "BotFather",
    "bouldering",
    "boulderingproject",
    "CACHEBUST",
    "castv",
    "castv2",
    "choco",
    "Chromecast",
    "Chromecasts",
    "clawhub",
    "cpus",
    "creds",
    "cutover",
    "deploy",
    "distroless",
    "DLNA",
    "dotenv",
    "ed25519",
    "esac",
    "gantry",
    "gcloudsdk",
    "gemini",
    "ghcr",
    "GOARCH",
    "GOCSPX",
    "googleusercontent",
    "googleworkspace",
    "gsub",
    "healthcheck",
    "Healthchecks",
    "Inspectable",
    "LASTEXITCODE",
    "ldflags",
    "libc",
    "libexec",
    "mcpbeam",
    "mem_limit",
    "mem_reservation",
    "newbot",
    "nogroup",
    "nonroot",
    "openclaw",
    "OpenSSH",
    "retrim",
    "rsync",
    "scp",
    "shotah",
    "SSDP",
    "Stealinglight",
    "STRAVA",
    "Supermix",
    "systray",
    "Telegram",
    "Timwiz",
    "tmpfs",
    "toml",
    "trimpath",
    "trixie",
    "tzdata",
    "userinfobot",
    "vulns",
    "ytmusic",
    "zchee",
    "zeroclaw",
    "ZeroClaw",
    "zeroclawlabs",
    "zerocode"
  ],
  "explorer.fileNesting.enabled": false
}
