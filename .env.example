# =============================================================================
# tim — a lean, self-hosted assistant on ai-gantry
#   make env          create .env from this file (skips if .env exists)
#   make env-force    overwrite .env from this file
# =============================================================================

# --- Timezone (recommended) --------------------------------------------------
# Docker defaults to UTC. Set an IANA zone so Tim's clock / cron match you.
# Examples: America/Los_Angeles, America/Denver, America/New_York, Europe/London
TZ=America/Los_Angeles

# --- Gemini (required) -------------------------------------------------------
# https://aistudio.google.com/apikey
# Also powers Google Search via mcp-gemini-google-search (docs/web-search.md).
# Paid / billing-enabled project required for search grounding.
GEMINI_API_KEY=
# Lean default; use gemini-3.5-pro (or similar) if you want more depth.
# Same value is passed to the Google Search MCP (avoid Pro-preview default there).
GEMINI_MODEL=gemini-3.5-flash
# Chat provider swap (any OpenAI-compatible endpoint — xAI, Ollama, …):
# override all three LLM_* and gantry uses them instead of the Gemini keys.
# Search stays on GEMINI_API_KEY either way. See docs/models.md.
# LLM_BASE_URL=https://api.x.ai/v1
# LLM_API_KEY=
# LLM_MODEL=grok-4.3

# --- Telegram (required) -----------------------------------------------------
# 1. Talk to @BotFather → /newbot → copy token
# 2. Message your bot, then get your user id via @userinfobot
# Guide: docs/telegram.md
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram numeric user IDs (not @usernames).
# Allowlist only — empty allowlist fails boot; there is no pairing flow.
TELEGRAM_ALLOWED_USERS=

# --- gantry knobs (optional; defaults in shotah/ai-gantry §5.1) ---------------
# STREAM_REPLIES=false          # true = Telegram edit-in-place streaming
# LOG_LEVEL=info
# HISTORY_MAX_MESSAGES=200
# HISTORY_MAX_TOKENS=128000     # estimated (chars/4)
# TOOL_RESULT_MAX_CHARS=16000
# TOOL_MAX_ITERATIONS=20
# MEMORY_ENABLED=true
# MEMORY_BACKEND=builtin        # or mcp:<server-name>
# MEMORY_CONSOLIDATE_MINUTES=30 # 0 = off
# CRON_ENABLED=true

# --- Google Workspace MCP (recommended) --------------------------------------
# Go binary: shotah/google-workspace-mcp-go (docs/google-workspace.md).
# Desktop OAuth client; redirect URI: http://localhost:4100/oauth2callback
# After setting these, run: make google-auth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
USER_GOOGLE_EMAIL=
# Defaults to GitHub latest each build. Pin only to freeze:
# GOOGLE_WORKSPACE_MCP_VERSION=v0.0.2

# --- Strava workout data (optional) ------------------------------------------
# Lets Tim read your activities (Garmin auto-syncs to Strava) for weekly
# summaries and "get to the gym / rest today" nudges via the strava-mcp tool.
# 1. Create an API app: https://www.strava.com/settings/api
#    (Authorization Callback Domain = localhost)
# 2. Copy the Client ID + Client Secret below.
# 3. Authorize once on a browser PC, then deploy. Guide: docs/strava.md
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# --- Garmin Connect (optional) -----------------------------------------------
# Sleep, Body Battery, HRV, Index scale weight, richer activities via go-garmin.
# No API app and no email/password here — one interactive login writes
# secrets/garmin/session.json (make garmin-auth). Guide: docs/garmin.md
# Optional: override go-garmin release tag (default in Dockerfile is v0.1.2).
# GARMIN_MCP_VERSION=v0.1.2

# --- Google Cast / house speakers (optional) ---------------------------------
# Local Chromecast / Nest / DLNA via mcp-beam (static Go, no API keys).
# Guide: docs/cast.md
# mDNS discovery needs host networking on a Linux home server:
# NETWORK_MODE=host
# (default is bridge — fine for Docker Desktop / no Cast)
# Defaults to GitHub latest each build. Pin only to freeze:
# MCP_BEAM_VERSION=v0.0.1
# MCP_BEAM_LOG_LEVEL=info

# --- YouTube Music (optional) ------------------------------------------------
# Search + library via youtube-go-mcp (static Go). Guide: docs/ytmusic.md
# Browser headers once: make ytmusic-auth → secrets/ytmusic/headers.json
# Defaults to GitHub latest each build. Pin only to freeze:
# YOUTUBE_GO_MCP_VERSION=v0.0.3

# --- Image / build (optional) ------------------------------------------------
# Compose builds a thin local image: distroless/static + gantry + the MCP tool
# binaries. GANTRY_IMAGE = local tag for the built image.
GANTRY_IMAGE=gantry-tim:local
# Our packages default to GitHub latest each build (TOOLS_CACHEBUST re-resolves).
# Uncomment only to override/pin a specific release:
# GANTRY_VERSION=<latest|vX.Y.Z; default latest>
# MCP_BEAM_VERSION=<latest|vX.Y.Z; default latest>
# YOUTUBE_GO_MCP_VERSION=<latest|vX.Y.Z; default latest>
# STRAVA_MCP_VERSION=<strava-mcp release tag>
# GARMIN_MCP_VERSION=<shotah/go-garmin release tag, e.g. v0.1.2>
# GEMINI_SEARCH_MCP_REF=<zchee/mcp-gemini-google-search git commit>
# GOOGLE_WORKSPACE_MCP_VERSION=<shotah/google-workspace-mcp-go release, e.g. v0.0.2>

# Host user inside the container (run `id -u` / `id -g` on the server)
GANTRY_UID=1000
GANTRY_GID=1000

# --- Remote Ubuntu deploy (optional) -----------------------------------------
# From Windows: needs OpenSSH Client. Then: make remote-deploy
# Guide: docs/deploy.md
DEPLOY_HOST=
DEPLOY_USER=ubuntu
DEPLOY_PATH=/gantry
DEPLOY_SSH_PORT=22
# Windows example: C:/Users/you/.ssh/id_ed25519
# Linux example:   ~/.ssh/id_ed25519
DEPLOY_SSH_KEY=
