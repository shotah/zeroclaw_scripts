# =============================================================================
# tim — a lean, self-hosted assistant on ZeroClaw
#   make env          create .env from this file (skips if .env exists)
#   make env-force    overwrite .env from this file
# =============================================================================

# --- Timezone (recommended) --------------------------------------------------
# Docker defaults to UTC. Set an IANA zone so Tim's clock / cron match you.
# Examples: America/Los_Angeles, America/Denver, America/New_York, Europe/London
TZ=America/Los_Angeles

# --- Gemini (required) -------------------------------------------------------
# https://aistudio.google.com/apikey
# Also powers Google Search via mcp-gemini-google-search (docs/web-search.md).
# Paid / billing-enabled project required for search grounding.
GEMINI_API_KEY=
# Lean default; use gemini-3.5-pro (or similar) if you want more depth.
# Same value is passed to the Google Search MCP (avoid Pro-preview default there).
# Compose also sets OPENAI_API_KEY from this key for ZeroClaw hybrid memory
# embeddings (Gemini OpenAI-compatible endpoint). See docs/telegram.md.
GEMINI_MODEL=gemini-3.5-flash

# --- Telegram (required) -----------------------------------------------------
# 1. Talk to @BotFather → /newbot → copy token
# 2. Message your bot, then get your user id via @userinfobot
# Guide: docs/telegram.md
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram numeric user IDs (not @usernames)
TELEGRAM_ALLOWED_USERS=

# --- Google Workspace MCP (recommended) --------------------------------------
# Go binary: magks/google-workspace-mcp-go (docs/google-workspace.md).
# Desktop OAuth client; redirect URI: http://localhost:4100/oauth2callback
# After setting these, run: make google-auth  (no local gws)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
USER_GOOGLE_EMAIL=
# Optional build pin:
# GOOGLE_WORKSPACE_MCP_REF=e421e4cea028e93575bb4e7b5ec1b3dc4a7084b6

# --- Strava workout data (optional) ------------------------------------------
# Lets Tim read your activities (Garmin auto-syncs to Strava) for weekly
# summaries and "get to the gym / rest today" nudges via the strava-mcp tool.
# 1. Create an API app: https://www.strava.com/settings/api
#    (Authorization Callback Domain = localhost)
# 2. Copy the Client ID + Client Secret below.
# 3. Authorize once on a browser PC, then deploy. Guide: docs/strava.md
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# --- Garmin Connect (optional) -----------------------------------------------
# Sleep, Body Battery, HRV, Index scale weight, richer activities via go-garmin.
# No API app and no email/password here — one interactive login writes
# secrets/garmin/session.json (make garmin-auth once wired). Guide: docs/garmin.md
# Optional: override go-garmin release tag (default in Dockerfile is v0.1.0).
# GARMIN_MCP_VERSION=v0.1.0

# --- Image / build (optional) ------------------------------------------------
# Compose builds a thin local image: distroless + gws + google-workspace-mcp-go + strava + garmin + gemini-search.
# ZEROCLAW_IMAGE = local tag for the built image.
ZEROCLAW_IMAGE=zeroclaw-gws:local
# The base image + tool versions are pinned once in the Dockerfile (single
# source of truth). Uncomment and set a value only to override/pin a specific
# release; leaving them commented uses the Dockerfile defaults.
# ZEROCLAW_BASE=ghcr.io/zeroclaw-labs/zeroclaw:<tag>
# GWS_VERSION=<gws release tag>
# STRAVA_MCP_VERSION=<strava-mcp release tag>
# GARMIN_MCP_VERSION=<shotah/go-garmin release tag, e.g. v0.1.0>
# GEMINI_SEARCH_MCP_REF=<zchee/mcp-gemini-google-search git commit>
# GOOGLE_WORKSPACE_MCP_REF=<magks/google-workspace-mcp-go git commit>
# Host deps (optional legacy gws export on auth PC): gcloud SDK + gws
#   Windows: choco install gcloudsdk
#   then:    npm i -g @googleworkspace/cli   # or grab gws from GitHub Releases

# Host user inside the container (run `id -u` / `id -g` on the server)
ZEROCLAW_UID=1000
ZEROCLAW_GID=1000

# Gateway / web dashboard host port (compose publishes this → container 42617).
# LAN access only — do not port-forward from your router.
GATEWAY_PORT=42617

# --- Remote Ubuntu deploy (optional) -----------------------------------------
# From Windows: needs OpenSSH Client. Then: make remote-deploy
# Guide: docs/deploy.md
DEPLOY_HOST=
DEPLOY_USER=ubuntu
DEPLOY_PATH=/zeroclaw
DEPLOY_SSH_PORT=22
# Windows example: C:/Users/you/.ssh/id_ed25519
# Linux example:   ~/.ssh/id_ed25519
DEPLOY_SSH_KEY=
