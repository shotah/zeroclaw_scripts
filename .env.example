# =============================================================================
# docker_open_claw → ZeroClaw (lean)
#   make env          create .env from this file (skips if .env exists)
#   make env-force    overwrite .env from this file
# =============================================================================

# --- Gemini (required) -------------------------------------------------------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Lean default; use gemini-2.5-pro if you want more depth
GEMINI_MODEL=gemini-2.5-flash

# --- Telegram (required) -----------------------------------------------------
# 1. Talk to @BotFather → /newbot → copy token
# 2. Message your bot, then get your user id via @userinfobot
# Guide: docs/telegram.md
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram numeric user IDs (not @usernames)
TELEGRAM_ALLOWED_USERS=

# --- Image (optional) --------------------------------------------------------
# Pin in production, e.g. ghcr.io/zeroclaw-labs/zeroclaw:v0.8.2
# Use :debian if you need `make shell` (distroless has no shell)
ZEROCLAW_IMAGE=ghcr.io/zeroclaw-labs/zeroclaw:latest

# --- Remote Ubuntu deploy (optional) -----------------------------------------
# From Windows: needs OpenSSH Client. Then: make remote-deploy
# Guide: docs/deploy.md
DEPLOY_HOST=
DEPLOY_USER=ubuntu
DEPLOY_PATH=/opt/zeroclaw
DEPLOY_SSH_PORT=22
# Windows example: C:/Users/you/.ssh/id_ed25519
# Linux example:   ~/.ssh/id_ed25519
DEPLOY_SSH_KEY=