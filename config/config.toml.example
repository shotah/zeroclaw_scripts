# Minimal ZeroClaw config — Gemini + Telegram (schema v3).
# Secrets are injected at runtime via .env / compose schema-mirror env vars.
# Synced into config/config.toml by: make sync-config
#
# Schema v3: inbound Telegram auth is peer_groups.*.external_peers
# (channel-level allowed_users was removed).

schema_version = 3

[providers.models.gemini.default]
model = "gemini-3.5-flash"
# api_key filled from GEMINI_API_KEY via ZEROCLAW_providers__models__gemini__default__api_key

[agents.main]
enabled = true
model_provider = "gemini.default"
risk_profile = "default"
channels = ["telegram.default"]
# Grant MCP servers to this agent. ZeroClaw is secure-by-default: servers in
# [mcp] are registered but only reach an agent via a bundle (see [mcp_bundles]).
mcp_bundles = ["strava", "garmin", "google-search"]

[channels.telegram.default]
enabled = true
# bot_token filled from TELEGRAM_BOT_TOKEN via env override

# Who may talk to the agent on telegram.default (from TELEGRAM_ALLOWED_USERS)
[peer_groups.telegram_default]
channel = "telegram.default"
agents = ["main"]
external_peers = []

# Full Google Workspace via gws (docs/google-workspace.md).
# Empty allowed_operations = all methods for the listed services.
[google_workspace]
enabled = true
credentials_path = "/zeroclaw-data/.config/gws/credentials.json"
allowed_services = [
  "gmail",
  "calendar",
  "docs",
  "drive",
  "sheets",
  "tasks",
  "people",
]
timeout_secs = 90
audit_log = true

# Strava workout data via the strava-mcp MCP server (docs/strava.md).
# Garmin Connect (sleep / weight / readiness) via go-garmin (docs/garmin.md).
# Google Search via Gemini grounding (docs/web-search.md) — same GEMINI_API_KEY.
# ZeroClaw launches each binary over stdio. Strava creds come from the container
# env; Garmin uses secrets/garmin/session.json on the mount (HOME=/zeroclaw-data).
[mcp]
enabled = true
# false = load MCP tool schemas eagerly so the model always sees them.
# With true, the model must call the built-in `tool_search` to activate MCP
# tools first; Gemini Flash doesn't reliably do that, so Strava tools appear
# "missing" and it falls back to Gmail (see docs/strava.md troubleshooting).
deferred_loading = false

[[mcp.servers]]
name = "strava"
transport = "stdio"
command = "strava-mcp"

[[mcp.servers]]
name = "garmin"
transport = "stdio"
command = "garmin"
args = ["mcp"]

[[mcp.servers]]
name = "google-search"
transport = "stdio"
command = "mcp-gemini-google-search"

# Bundle that grants the "strava" MCP server. Referenced by agents.main.mcp_bundles.
# Without this grant the agent sees zero Strava tools and improvises (e.g. Gmail).
[mcp_bundles.strava]
servers = ["strava"]

[mcp_bundles.garmin]
servers = ["garmin"]

[mcp_bundles.google-search]
servers = ["google-search"]

# Built-in ZeroClaw web_search defaults to DuckDuckGo scraping, which Docker IPs
# get blocked for. Prefer the google-search MCP (Gemini grounding) above.
[web_search]
enabled = false

# Web access for Tim's `web_fetch` tool. Matching is by domain (exact or
# subdomain) — no scheme, no path. `blocked_domains` ALWAYS wins over allowed.
#
# The widest possible whitelist is just ["*"] (every public site) — that's the
# default and what we keep here so Tim is never "locked off" and you avoid the
# onesie-twosie churn. Use `blocked_domains` to ban specific sites.
#
# If you ever want the opposite (a strict allowlist — Tim may ONLY reach these),
# comment out the ["*"] line and uncomment the curated list below.
[web_fetch]
allowed_domains = ["*"]
# allowed_domains = [
#   "strava.com",
#   "github.com",
#   "wikipedia.org",
#   "arketa.co",              # ROQ / yoga class booking
#   "boulderingproject.com",  # bouldering gym
#   # "your-yoga-studio.com", # add your studio's domain
# ]
blocked_domains = [
  # Sites Tim must never fetch, even though allowed_domains = ["*"]:
  # "facebook.com",
  # "x.com",
]
# Internal/LAN hosts are blocked by default (SSRF protection). List any you
# want Tim to reach, e.g. a home server: allowed_private_hosts = ["nas.local"]
# allowed_private_hosts = []

[gateway]
host = "127.0.0.1"
port = 42617
allow_public_bind = false
require_pairing = false

[risk_profiles.default]
# Autonomy levels (ZeroClaw built-in — no custom boolean needed):
#   readonly    — observe only
#   supervised  — medium-risk tools ask / get denied on channels (default)
#   full        — no approval prompts; forbidden_paths / sandbox still apply  ← Tim
#   yolo        — nuke all gates (shell, paths, sandbox). Overkill for a bot
#                 that has Gmail + a Telegram allowlist; use only on a throwaway box.
# Same idea as web_fetch allowed_domains = ["*"]: stop enumerating every tool.
level = "full"
auto_approve = ["*"]
# Optional: force a prompt for specific tools even under full (rarely needed):
# always_ask = ["shell"]
